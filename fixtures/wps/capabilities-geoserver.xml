<?xml version="1.0" encoding="UTF-8"?>
<wps:Capabilities service="WPS" version="1.0.0" xml:lang="en"
    xmlns:wps="http://www.opengis.net/wps/1.0.0"
    xmlns:ows="http://www.opengis.net/ows/1.1"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    updateSequence="1">
  <ows:ServiceIdentification>
    <ows:Title>Demo WPS</ows:Title>
    <ows:Abstract>Web Processing Service for the demo GeoServer instance</ows:Abstract>
    <ows:Keywords>
      <ows:Keyword>WPS</ows:Keyword>
      <ows:Keyword>geospatial</ows:Keyword>
      <ows:Keyword>geoprocessing</ows:Keyword>
    </ows:Keywords>
    <ows:ServiceType>WPS</ows:ServiceType>
    <ows:ServiceTypeVersion>1.0.0</ows:ServiceTypeVersion>
    <ows:Fees>NONE</ows:Fees>
    <ows:AccessConstraints>NONE</ows:AccessConstraints>
  </ows:ServiceIdentification>
  <ows:ServiceProvider>
    <ows:ProviderName>Example Org</ows:ProviderName>
    <ows:ProviderSite xlink:href="https://www.example.org"/>
    <ows:ServiceContact>
      <ows:IndividualName>Jane Doe</ows:IndividualName>
      <ows:PositionName>GIS Manager</ows:PositionName>
      <ows:ContactInfo>
        <ows:Phone>
          <ows:Voice>+00 00 000 0000</ows:Voice>
        </ows:Phone>
        <ows:Address>
          <ows:City>Metropolis</ows:City>
          <ows:Country>Wonderland</ows:Country>
          <ows:ElectronicMailAddress>jane@example.org</ows:ElectronicMailAddress>
        </ows:Address>
      </ows:ContactInfo>
    </ows:ServiceContact>
  </ows:ServiceProvider>
  <ows:OperationsMetadata>
    <ows:Operation name="GetCapabilities">
      <ows:DCP>
        <ows:HTTP>
          <ows:Get xlink:href="https://my.wps.server/geoserver/ows?"/>
          <ows:Post xlink:href="https://my.wps.server/geoserver/ows?"/>
        </ows:HTTP>
      </ows:DCP>
    </ows:Operation>
    <ows:Operation name="DescribeProcess">
      <ows:DCP>
        <ows:HTTP>
          <ows:Get xlink:href="https://my.wps.server/geoserver/ows?"/>
          <ows:Post xlink:href="https://my.wps.server/geoserver/ows?"/>
        </ows:HTTP>
      </ows:DCP>
    </ows:Operation>
    <ows:Operation name="Execute">
      <ows:DCP>
        <ows:HTTP>
          <ows:Get xlink:href="https://my.wps.server/geoserver/ows?"/>
          <ows:Post xlink:href="https://my.wps.server/geoserver/wps"/>
        </ows:HTTP>
      </ows:DCP>
    </ows:Operation>
  </ows:OperationsMetadata>
  <wps:ProcessOfferings>
    <wps:Process wps:processVersion="1.0.0">
      <ows:Identifier>JTS:buffer</ows:Identifier>
      <ows:Title>Buffer a geometry</ows:Title>
      <ows:Abstract>Returns the buffer of a geometry by a given distance</ows:Abstract>
    </wps:Process>
    <wps:Process wps:processVersion="2.0.0">
      <ows:Identifier>ras:Contour</ows:Identifier>
      <ows:Title>Contour</ows:Title>
      <ows:Abstract>Extracts contours from a raster</ows:Abstract>
    </wps:Process>
  </wps:ProcessOfferings>
</wps:Capabilities>
